---
import '../styles/global.css';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';
import Clock from '../components/Clock';
import WeatherWidget from '../components/WeatherWidget';

const reader = createReader(process.cwd(), keystaticConfig);
const site = await reader.singletons.site.read();
const allPhotos = await reader.collections.photos.all();

const shuffled = [...allPhotos].sort(() => Math.random() - 0.5);
const [p1, p2, p3] = shuffled;
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>{site?.name ?? 'Bento'}</title>
  </head>
  <body>

    <div class="grid">

      <!-- Photo 1 — hero, spans 2 rows -->
      {p1?.entry.image && (
        <div class="cell photo1">
          <img src={p1.entry.image} alt={p1.entry.alt_text ?? p1.entry.title} />
        </div>
      )}

      <!-- Bio -->
      <div class="cell bio card">
        <span class="label">Fotograf</span>
        <div>
          <h1>{site?.name}</h1>
          <p class="tagline">{site?.tagline}</p>
        </div>
        <div class="links">
          {site?.email && <a href={`mailto:${site.email}`}>{site.email}</a>}
          {site?.instagram && (
            <a href={`https://instagram.com/${site.instagram}`} target="_blank" rel="noopener">
              @{site.instagram}
            </a>
          )}
          <a href="/" class="back">← Portfolio</a>
        </div>
      </div>

      <!-- Weather -->
      <div class="cell weather card">
        <span class="label">Vejr · København</span>
        <WeatherWidget client:load />
        <span class="muted">Open-Meteo · live</span>
      </div>

      <!-- Clock — React island -->
      <div class="cell clock card">
        <Clock client:load />
      </div>

      <!-- Photo 2 -->
      {p2?.entry.image && (
        <div class="cell photo2">
          <img src={p2.entry.image} alt={p2.entry.alt_text ?? p2.entry.title} />
        </div>
      )}

      <!-- Photo 3 -->
      {p3?.entry.image && (
        <div class="cell photo3">
          <img src={p3.entry.image} alt={p3.entry.alt_text ?? p3.entry.title} />
        </div>
      )}

      <!-- Spotify — Deep Focus
           To swap: Spotify → Share → Copy link → paste ID here -->
      <div class="cell spotify">
        <iframe
          src="https://open.spotify.com/embed/playlist/37i9dQZF1DWZeKCadgRdKQ?utm_source=generator"
          width="100%" height="100%"
          frameborder="0"
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          loading="lazy"
        ></iframe>
      </div>

    </div>

    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; }

      body {
        background: #ede8dc;
        color: #1c1814;
        font-family: system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
        min-height: 100dvh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 16px;
      }

      /* ── Grid — max 960px wide, rows capped by clamp ──── */
      .grid {
        display: grid;
        width: 100%;
        max-width: 960px;
        gap: 10px;

        grid-template-columns: 1fr 1.3fr 1fr;
        grid-template-rows:
          clamp(160px, 22vh, 260px)
          clamp(120px, 15vh, 180px)
          clamp(140px, 18vh, 220px);
        grid-template-areas:
          "photo1  bio      weather"
          "photo1  clock    photo2"
          "photo3  spotify  spotify";
      }

      /* ── Cell base ────────────────────────────────────── */
      .cell {
        border-radius: 14px;
        overflow: hidden;
        min-height: 0;
        min-width: 0;
      }

      .photo1  { grid-area: photo1; }
      .bio     { grid-area: bio; }
      .weather { grid-area: weather; }
      .clock   { grid-area: clock; }
      .photo2  { grid-area: photo2; }
      .photo3  { grid-area: photo3; }
      .spotify { grid-area: spotify; }

      /* ── Photos ───────────────────────────────────────── */
      .cell img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      /* ── Content cards ────────────────────────────────── */
      .card {
        background: #f5f1e8;
        padding: 16px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }

      .label {
        font-size: 10px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #9a8e82;
      }

      .muted { color: #b0a498; font-size: 11px; }

      /* Bio */
      h1 { font-size: clamp(1.1rem, 1.8vw, 1.6rem); font-weight: 300; line-height: 1.15; }
      .tagline { color: #7a6e62; font-size: 0.78rem; margin-top: 4px; }
      .links { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
      .links a { color: #7a6e62; font-size: 0.75rem; text-decoration: none; transition: color 0.15s; }
      .links a:hover { color: #1c1814; }
      .links .back { margin-left: auto; color: #b0a498; }

      /* Weather */
      .weather-body { display: flex; flex-direction: column; gap: 2px; }
      .weather-emoji { font-size: 1.8rem; line-height: 1; }
      .weather-temp  { font-size: clamp(1.6rem, 2.5vw, 2.4rem); font-weight: 200; line-height: 1; }
      .weather-label { color: #7a6e62; font-size: 0.75rem; }

      /* ── Mobile: 2-col stack ──────────────────────────── */
      @media (max-width: 600px) {
        body { padding: 10px; align-items: flex-start; }

        .grid {
          grid-template-columns: 1fr 1fr;
          grid-template-rows: auto;
          grid-template-areas:
            "bio     bio"
            "photo1  photo2"
            "weather clock"
            "photo3  photo3"
            "spotify spotify";
        }

        .cell.photo1,
        .cell.photo2,
        .cell.photo3 { aspect-ratio: 1; }
        .cell.weather, .cell.clock { min-height: 130px; }
        .cell.spotify { min-height: 180px; }
      }
    </style>

  </body>
</html>
